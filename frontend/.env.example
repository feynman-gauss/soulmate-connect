# Backend API URL Configuration
# Leave empty for automatic detection based on current hostname
# This works for:
# - Local development (localhost:8000)
# - Network access from other devices (auto-detects IP)
# - Production (when set explicitly)

# For production deployments, set to your backend URL:
# VITE_API_URL=https://api.your-domain.com/api/v1

# For local development, leave empty or commented out:
# VITE_API_URL=
